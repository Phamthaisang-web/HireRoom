Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6Niwicm9sZSI6ImFkbWluIiwiaWF0IjoxNzc0NDU4NDk2LCJleHAiOjE3NzQ1NDQ4OTZ9.HbOPBUEZWLtF2xz0N_04E9OoltrYPoe_R7Z_geYqlRM
Content-Type: application/json

{
  "roomId": 1
}

